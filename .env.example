# ============================================================================
# PostgreSQL
# ============================================================================
db_user=postgres
db_password=your_password
db_host=db
db_port=5432
db_database=arbitrage_system

# ============================================================================
# БКС Trade API
# ============================================================================
BCS_REFRESH_TOKEN=your_bcs_refresh_token
BCS_TOKEN_CACHE_PATH=
BCS_SSL_VERIFY=true

# ============================================================================
# EXANTE API
# ============================================================================
EXANTE_API_KEY=
EXANTE_SECRET_KEY=
EXANTE_SHARED_KEY=
EXANTE_CLIENT_ID=
EXANTE_APPLICATION_ID=
EXANTE_JWT=
EXANTE_MD_API=https://api-live.exante.eu/md
EXANTE_TRADE_API=https://api-live.exante.eu/trade
EXANTE_API_VERSION=3.0
EXANTE_SSL_VERIFY=true

# ============================================================================
# Общие настройки HTTP
# ============================================================================
HTTP_TIMEOUT_TOTAL=12
HTTP_TIMEOUT_CONNECT=5
HTTP_TIMEOUT_SOCK_READ=18
HTTP_RETRIES=2
HTTP_RETRY_BACKOFF=0.7
